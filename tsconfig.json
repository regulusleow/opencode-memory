{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "noImplicitAny": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}


